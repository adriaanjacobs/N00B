#pragma once

#define TAG_WIDTH                   (${TAG_WIDTH})
#define NOOB_TOPTAG_START           (${NOOB_TOPTAG_START})
static_assert(NOOB_TOPTAG_START + TAG_WIDTH <= 64);
#define NOOB_MIN_RADIX              (${NOOB_MIN_RADIX})
#define NON_NOOB_MIN_RADIX          (${NON_NOOB_MIN_RADIX})
#cmakedefine01 NOOB_IGNORE_ERRORS
#cmakedefine01 NOOB_TAG_POINTERS
#define NOOB_MAX_ADDR               (${NOOB_MAX_ADDR})

#define ARITH_LEEWAY_WIDTH          (${ARITH_LEEWAY_WIDTH})
static_assert(ARITH_LEEWAY_WIDTH == 0, "we don't need to permit additional arithmetic");
#define ARITH_LEEWAY_OCCUPIED_BITS  (${ARITH_LEEWAY_OCCUPIED_BITS})
static_assert(ARITH_LEEWAY_OCCUPIED_BITS < (1U << ARITH_LEEWAY_WIDTH));
#define NOOB_STACK_SIZE             (${NOOB_STACK_SIZE})

#cmakedefine01 CHECK_DEREFERENCE_SITES
#cmakedefine01 CHECK_ESCAPE_SITES
#cmakedefine01 CHECK_POINTER_ARITHMETIC
#cmakedefine01 CHECK_POINTER_DEREFERENCES
#cmakedefine01 USE_BRANCHING_CHECKS
#cmakedefine01 INTRAPROCEDURAL_ONLY
#cmakedefine01 SOUND_POINTER_DETECTION

#cmakedefine01 MASK_EXT_PTR_ARGS
#cmakedefine01 COUNT_NOOB_FAILURES

#cmakedefine01 REPLACE_STACK_ALLOCS
#cmakedefine01 REMAP_GLOBALS

#cmakedefine01 EMIT_RUNTIME_CALLS
#cmakedefine01 TRACK_ARITH_STATS

#cmakedefine01 EMULATE_LOWFAT
#cmakedefine01 PAD_BY_ONE_BYTE
