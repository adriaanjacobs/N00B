#! /bin/bash
# Short script that applies NOOB flags to clang-15

set -e

# Figure out whether this script was invoked as "noobclang" or "noobclang++"
invocation_name=$(basename "$0")

if [[ "$invocation_name" == *"++" ]]; then
    clang_command="clang++-15"
else
    clang_command="clang-15"
fi

# Check if clang_command is empty or invalid
if [[ -z "$clang_command" ]]; then
    >&2 echo "Error: could not find command: $clang_command"
    exit 1
fi

# Check if we are linking (not compile-only, preprocess-only, or assemble-only)
linking=1
for arg in "$@"; do
    if [[ "$arg" == "-c" || "$arg" == "-S" || "$arg" == "-E" ]]; then
        linking=0
        break
    fi
done

# Base flags
flags=("-flto" "-Xclang" "-no-opaque-pointers")

# Add linker flags if linking
if [[ $linking -eq 1 ]]; then
    flags+=(
        "-fuse-ld=lld-15"
        @NOOB_PLUGIN_FLAGS@
        "-Wl,-rpath=@CMAKE_BINARY_DIR@/allocator/"
        "@CMAKE_BINARY_DIR@/allocator/libnooballoc.so"
        "-Wl,-dynamic-linker,@CMAKE_BINARY_DIR@/n00bloader/n00bloader"
    )
fi

set -x

# Actual invocation here
$clang_command "$@" "${flags[@]}"
