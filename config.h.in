#pragma once

#define TAG_WIDTH                   (${TAG_WIDTH})
static_assert(TAG_WIDTH == 8, "we make this assumption almost everywhere in the source at this point");
#define ARITH_LEEWAY_WIDTH          (${ARITH_LEEWAY_WIDTH})
static_assert(ARITH_LEEWAY_WIDTH == 0, "we don't need to permit additional arithmetic");
#define ARITH_LEEWAY_OCCUPIED_BITS  (${ARITH_LEEWAY_OCCUPIED_BITS})
static_assert(ARITH_LEEWAY_OCCUPIED_BITS < (1U << ARITH_LEEWAY_WIDTH));
#define NOOB_STACK_SIZE             (${NOOB_STACK_SIZE})
#define NOOB_COMPAT_MIN_ADDR        (${NOOB_COMPAT_MIN_ADDR})

#define CHECK_POINTER_DEREFERENCES  ${CHECK_POINTER_DEREFERENCES}
#define CHECK_POINTER_ARITHMETIC    ${CHECK_POINTER_ARITHMETIC}
#define ARITH_CHECK_BRANCH          ${ARITH_CHECK_BRANCH}
#define REPLACE_STACK_ALLOCS        ${REPLACE_STACK_ALLOCS}
#define REMAP_GLOBALS               ${REMAP_GLOBALS}

#define EMIT_RUNTIME_CALLS          ${EMIT_RUNTIME_CALLS}
